<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ระบบย่อลิงก์อย่างง่ายด้วย GitHub และ Google Sheets</title>
  <style>
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f4f6f9;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      margin: 0;
    }
    .container {
      background-color: white;
      padding: 40px;
      border-radius: 12px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.08);
      width: 100%;
      max-width: 480px;
      text-align: center;
    }
    h2 {
      color: #2c3e50;
      margin-bottom: 25px;
    }
    input[type="url"] {
      width: 90%;
      padding: 12px;
      margin-bottom: 15px;
      border: 1px solid #cbd5e1;
      border-radius: 6px;
      font-size: 16px;
      outline: none;
    }
    input[type="url"]:focus {
      border-color: #3498db;
    }
    button {
      background-color: #3498db;
      color: white;
      border: none;
      padding: 12px 30px;
      font-size: 16px;
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.2s;
    }
    button:hover {
      background-color: #2980b9;
    }
    .result-box {
      margin-top: 25px;
      padding: 15px;
      background-color: #e8f4fd;
      border: 1px dashed #3498db;
      border-radius: 6px;
      display: none;
      word-break: break-all;
    }
    .result-box a {
      color: #2980b9;
      font-weight: bold;
      text-decoration: none;
    }
    .status-msg {
      display: none;
      color: #7f8c8d;
      margin-top: 15px;
      font-size: 16px;
    }
    .main-ui {
      display: block;
    }
  </style>
</head>
<body>

<div class="container">
  <div id="statusMsg" class="status-msg">กำลังตรวจสอบข้อมูลลิงก์...</div>

  <div id="mainUi" class="main-ui">
    <h2>ระบบย่อลิงก์ (URL Shortener)</h2>
    <input type="url" id="longUrl" placeholder="วางลิงก์ยาวๆ ของคุณที่นี่..." required>
    <br>
    <button onclick="makeShortUrl()">ย่อลิงก์เลย</button>
    
    <div id="resultBox" class="result-box">
      <p style="margin-top:0; color:#555;">ลิงก์สั้นของคุณพร้อมใช้งานแล้ว:</p>
      <a id="shortLink" href="#" target="_blank"></a>
    </div>
  </div>
</div>

<script>
  // ตรงนี้สำคัญมาก!!: ให้เอาลิงก์ Web App ของ Google Apps Script ที่ได้จากขั้นตอนที่ 1 มาวางแทนที่ในเครื่องหมายคำพูดนี้ครับ
  const WEB_APP_URL = "https://script.google.com/macros/s/AKfycbw71dCHInSkZK7bX9mzXlU-AlNxGNX1iM_mieXlI53IcaU1Z4gDbXvGTXfJ_99DcqwP/exec";

  // ส่วนตรวจสอบเพื่อแปลงหน้า (Redirect Link) อัตโนมัติเมื่อมีคนกดลิงก์สั้นเข้ามา
  window.onload = function() {
    const urlParams = new URLSearchParams(window.location.search);
    const id = urlParams.get('id');

    if (id) {
      // ซ่อนหน้าเว็บปกติ และแสดงตัวโหลดข้อความแทน
      document.getElementById('mainUi').style.display = 'none';
      var status = document.getElementById('statusMsg');
      status.style.display = 'block';
      status.innerText = "กำลังนำคุณไปยังหน้าเว็บปลายทาง...";

      // วิ่งไปถามเซิร์ฟเวอร์ Google Sheets ว่ารหัสนี้คู่กับลิงก์ยาวตัวไหน
      fetch(`${WEB_APP_URL}?action=get&id=${id}`)
        .then(response => response.json())
        .then(data => {
          if (data.success && data.originalUrl) {
            window.location.href = data.originalUrl; // พาวาร์ปย้ายหน้าทันที
          } else {
            status.innerHTML = `<h3 style="color:#e74c3c;">ขออภัย! ไม่พบลิงก์นี้ในระบบ หรืออาจจะถูกลบไปแล้ว</h3>`;
          }
        })
        .catch(error => {
          status.innerHTML = `<h3 style="color:#e74c3c;">เกิดข้อผิดพลาดในการเชื่อมต่อระบบฐานข้อมูล</h3>`;
        });
    }
  };

  // ส่วนของการกดย่อลิงก์
  function makeShortUrl() {
    var longUrl = document.getElementById('longUrl').value;
    if(!longUrl) {
      alert('กรุณาใส่ลิงก์ยาวก่อนกดปุ่มครับ');
      return;
    }
    
    var status = document.getElementById('statusMsg');
    status.style.display = 'block';
    status.innerText = "กำลังสร้างลิงก์...";
    document.getElementById('resultBox').style.display = 'none';
    
    // เข้ารหัส URL ป้องกันกรณีลิงก์ยาวมีตัวอักษรพิเศษชวนพัง เช่น & หรือ ?
    var encodedUrl = encodeURIComponent(longUrl);

    // ยิง Fetch API ข้ามโดเมนไปหา Google Script เพื่อเก็บบันทึกข้อมูล
    fetch(`${WEB_APP_URL}?action=shorten&url=${encodedUrl}`)
      .then(response => response.json())
      .then(data => {
        status.style.display = 'none';
        if(data.success) {
          // ดึงเอา URL ปัจจุบันของ GitHub Pages มาต่อท้ายด้วยรหัส 6 หลักที่ได้คืนมา
          var currentBaseUrl = window.location.href.split('?')[0];
          var shortUrl = currentBaseUrl + '?id=' + data.id;
          
          var link = document.getElementById('shortLink');
          link.href = shortUrl;
          link.innerText = shortUrl;
          document.getElementById('resultBox').style.display = 'block';
        } else {
          alert('ผิดพลาด: ' + data.message);
        }
      })
      .catch(error => {
        status.style.display = 'none';
        alert('เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์');
        console.error(error);
      });
  }
</script>

</body>
</html>
